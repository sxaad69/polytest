# ─────────────────────────────────────────────────────────────────────────────
# Polymarket Dual Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PAPER TESTING (only this section needed to start) ─────────────────────────

# Alchemy free tier — Ethereum Mainnet
# Get it at: https://dashboard.alchemy.com → Create App → Ethereum Mainnet
# Copy the HTTPS URL exactly as shown
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/OGOyrM3TkmlP943B-ZLDi


# ── LIVE TRADING ONLY (leave blank during paper testing) ─────────────────────

# Your Magic Link wallet private key (WITHOUT the 0x prefix)
# Export at: https://reveal.magic.link/polymarket
# WARNING: Never share this with anyone. Never screenshot it.
POLYMARKET_PRIVATE_KEY=

# Your Polymarket funder address (the address shown in your Polymarket profile)
# This is different from your Magic wallet address — see README for explanation
POLYMARKET_FUNDER_ADDRESS=

# Polymarket API credentials
# Generated by running: python scripts/get_api_key.py  (after setting PK above)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=
